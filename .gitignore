# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Env variables
.env
/src/config
data/
/logs
# Runtime logs are written under src/logs/ too (anchored /logs only covers root).
src/logs/
