# snapshot lives (tracked) in docs/artifacts/kmeans_search/.
src/kmeans_search/
# Jupyter checkpoint dirs — never useful in VCS.
**/.ipynb_checkpoints/
/src/notebooks
*.json
!tests/fixtures/**/*.json
!frontend/**/*.json
.claude/
/src/preprocessing/images/
/src/preprocessing/notebooks/images.txt
/src/data/
**/runs/
**/runs/*/*/weights/
**/data/
*.pt
*.onnx

# Frontend
node_modules/
!frontend/package.json
!frontend/package-lock.json
